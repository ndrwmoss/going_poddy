echo "INIT: CUDA"
$PODDY/boot/cuda

echo "INIT: COMFY"
$PODDY/boot/comfy

echo "INIT: SAGE"
$PODDY/boot/sage

echo "INIT: SSH"
$PODDY/boot/ssh

echo "INIT: NGINX"
$PODDY/boot/nginx

echo "INIT: JUPYTER"
$PODDY/boot/jupyter

# Runs update.
if [[ $REPO == "none" ]]; then
    echo "FETCHING WORKFLOWS"
    $PODDY/boot/update
elif [[ $REPO == test ]]; then
    $PODDY/boot/update
    echo "FETCHING TEST PACKAGES"
    $PODDY/boot/update test
else
    echo "FETCHING WORKFLOWS"
    $PODDY/boot/update
    $PODDY/boot/update $rep
fi

# Runs installers if PREINSTALL is set to a non-empty string.
if [[ $PREINSTALL != "none" ]]; then
    echo "INIT: installing $PREINSTALL package"
    /poddy i $PREINSTALL
else
    echo "INIT: No Going Poddy packages selected. To install packages open a terminal and type: /poddy i name_of_package_to_install."
fi

$PODDY/cmd/update_nodes

